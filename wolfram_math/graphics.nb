Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"x", "^", "2"}], "*", 
    RowBox[{"Exp", "[", 
     RowBox[{"-", 
      RowBox[{"ax", "^", "2"}]}], "]"}]}], ",", "  ", "x", ",", " ", "k"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.987401300785109*^9, 3.98740133335535*^9}, {
  3.987401382999153*^9, 3.987401383078411*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"19f98f7f-6380-4fe4-ae56-82f1fdfa9747"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     SuperscriptBox["ax", "2"]}]]}], " ", 
  SqrtBox[
   RowBox[{"2", " ", "\[Pi]"}]], " ", 
  RowBox[{
   SuperscriptBox["DiracDelta", "\[Prime]\[Prime]",
    MultilineFunction->None], "[", "k", "]"}]}]], "Output",
 CellChangeTimes->{3.987401335394519*^9, 3.987401385078793*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"05067b56-a923-403a-b74d-5a690632e3c7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FourierTransform", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"a", "^", "2"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"x", "^", "2"}], "+", 
      RowBox[{"a", "^", "2"}]}], ")"}]}], ",", " ", "x", ",", " ", "k"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.98740135460131*^9, 3.987401417717516*^9}},
 CellLabel->"In[8]:=",ExpressionUUID->"6f7594eb-cc35-448f-a1a8-ad5e852a3370"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", "a", " ", 
  SuperscriptBox["\[ExponentialE]", 
   RowBox[{
    RowBox[{"-", "a"}], " ", "k"}]], " ", 
  SqrtBox[
   FractionBox["\[Pi]", "2"]], " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "a", " ", "k"}]]}], ")"}], " ", 
     RowBox[{"Sign", "[", "k", "]"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "1"}], "+", 
       RowBox[{"Sign", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{"Re", "[", "a", "]"}], "]"}], "]"}]}], ")"}]}], "+", 
    RowBox[{"2", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", " ", "a", " ", "k"}]], " ", 
        RowBox[{"HeavisideTheta", "[", 
         RowBox[{
          RowBox[{"-", "k"}], " ", 
          RowBox[{"Sign", "[", 
           RowBox[{"Re", "[", "a", "]"}], "]"}]}], "]"}]}], "+", 
       RowBox[{"HeavisideTheta", "[", 
        RowBox[{"k", " ", 
         RowBox[{"Sign", "[", 
          RowBox[{"Re", "[", "a", "]"}], "]"}]}], "]"}]}], ")"}], " ", 
     RowBox[{"Sign", "[", 
